{
  "poppler_path": "C:/poppler-24.07.0/Library/bin",
  "ocr_preprocess": true,
  "ocr_dpi": 420,
  "ocr_keyword_box_margin": 40,

  "stop_keywords": [
    "病院", "医院", "大学", "センター", "組合", "会社", "株式会社", "有限会社",
    "工業", "電力", "商事", "製作所", "建設", "設備", "役場", "市役所", "庁"
  ],

  "targets": {
    "法人名": {
      "regex": [
        "(?:宛|御中)?\\s*([\\u4E00-\\u9FFF\\u3040-\\u30FFA-Za-z一-龠々ヶ\\s　]+?)(?:\\s*(?:御中|様))",
        "^(?:株式会社|有限会社|医療法人|学校法人|社会福祉法人|合同会社)[^\\n]+",
        "([\\u4E00-\\u9FFF\\u3040-\\u30FFA-Za-z一-龠々ヶ]+?(?:病院|会社|株式会社|大学|センター|組合))"
      ]
    },
    "契約電力": {
      "regex": [
        "主契約\\s*[:：]?\\s*([0-9]+(?:\\.[0-9]+)?)\\s*kW(?!/)",
        "契約電力\\s*[:：]?\\s*([0-9]+(?:\\.[0-9]+)?)\\s*kW(?!/)",
        "基本契約[^\\n]*?([0-9]+(?:\\.[0-9]+)?)\\s*kW(?!/)",
        "(?<!/)([0-9]+(?:\\.[0-9]+)?)\\s*(?:kW|ｋＷ|ＫＷ)(?!/)"
      ],
      "keywords_for_region_ocr": ["主契約", "契約電力", "基本契約", "契約力"]
    }
  },

  "excel_cell_map": {
    "sheet": "高圧",
    "法人名": "B1",
    "契約電力": "G12"
  }
}
